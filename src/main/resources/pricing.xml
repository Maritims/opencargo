<?xml version="1.0" encoding="utf-8" ?>
<pricingPolicies xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:noNamespaceSchemaLocation="../xsd/pricing.xsd">
    <pricingPolicy id="1">
        <name>Foo bar</name>
        <basePrice>135.0</basePrice>
        <priority>1</priority>
        <pricingRules>
            <geographicPricingRule id="1">
                <countrySpecification>
                    <countryCode>NO</countryCode>
                </countrySpecification>
            </geographicPricingRule>
            <weightLimitRule id="2">
                <maxWeight>35.0</maxWeight>
            </weightLimitRule>
            <productRequirementRule id="3">
                <product id="3"/>
            </productRequirementRule>
        </pricingRules>
        <priceModifiers>
            <geographicSurcharge id="1">
                <name>Tillegg for transport til Svalbard</name>
                <percentage>15.0</percentage>
                <countrySpecification>
                    <countryCode>NO</countryCode>
                    <postalCodeSpecification xsi:type="PostalCodeRangeSpecificationDTO" minInclusive="9170" maxInclusive="9178"/>
                </countrySpecification>
            </geographicSurcharge>
        </priceModifiers>
    </pricingPolicy>
</pricingPolicies>