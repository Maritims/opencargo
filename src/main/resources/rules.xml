<?xml version="1.0" encoding="UTF-8" ?>
<rules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="../xsd/rules.xsd">
    <geographyRule id="1">
        <number>1</number>
        <name>Posten Norge er kun tilgjengelig i Norge</name>
        <priority>0</priority>
        <targets>
            <product id="1"/>
            <product id="2"/>
        </targets>
        <countrySpecification>
            <countryCode>NO</countryCode>
            <postalCodeSpecification xsi:type="PostalCodeRangeSpecificationDTO" minInclusive="0001" maxInclusive="9999"/>
            <postalCodeSpecification xsi:type="PostalCodeSetSpecificationDTO">
                <postalCode>3261</postalCode>
            </postalCodeSpecification>
        </countrySpecification>
    </geographyRule>
    <weightRule id="2">
        <number>2</number>
        <name>Pakke til hentested har en maksimum vekt på 35 kilo</name>
        <priority>0</priority>
        <targets>
            <product id="1"/>
        </targets>
        <maxExclusive>35.0</maxExclusive>
    </weightRule>
    <weightRule id="3">
        <number>3</number>
        <name>Pakkeboks har en maskimumvekt på 10 kilo</name>
        <priority>0</priority>
        <targets>
            <product id="2"/>
        </targets>
        <maxExclusive>10.0</maxExclusive>
    </weightRule>
    <minDimensionsRule id="3">
        <number>4</number>
        <name>Pakke til hentested har minimumsmål 15 x 10 x 1 cm</name>
        <priority>0</priority>
        <targets>
            <product id="1"/>
            <product id="2"/>
        </targets>
        <minWidth>15.0</minWidth>
        <minLength>10.0</minLength>
        <minHeight>1.0</minHeight>
    </minDimensionsRule>
    <lengthOrGirthRule id="4">
        <number>5</number>
        <name>Pakke til hentested kan enten være maksimalt 240 cm lang, eller ha en maks lengde + omkrets på 360 cm</name>
        <priority>0</priority>
        <targets>
            <product id="1"/>
            <product id="2"/>
        </targets>
        <maxLength>240.0</maxLength>
        <maxLengthAndGirthCombined>360.0</maxLengthAndGirthCombined>
    </lengthOrGirthRule>
</rules>